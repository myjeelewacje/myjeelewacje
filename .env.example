# Publiczny adres strony
NEXT_PUBLIC_SITE_URL=https://myjeelewacje.pl

# Payload CMS
PAYLOAD_SECRET=zmien-to-na-dlugi-losowy-sekret-minimum-32-znaki
DATABASE_URI=postgresql://USER:PASSWORD@HOST:5432/DATABASE?sslmode=require

# Formularz zapytania - e-mail docelowy
LEADS_TO_EMAIL=kontakt@myjeelewacje.pl

# SMTP / Resend ustawimy w kolejnym kroku po wdrożeniu
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=

# Opcjonalnie storage zdjęć w przyszłości
S3_BUCKET=
S3_REGION=auto
S3_ENDPOINT=
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
